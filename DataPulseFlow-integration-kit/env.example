# Copy to .env locally for scripts only — never commit real secrets.

# Supabase (for register-shopify-webhooks.mjs via CLI api-keys fetch)
SUPABASE_PROJECT_REF=your_project_ref

# Optional: override default callback URL built from project ref
# SHOPIFY_WEBHOOK_CALLBACK_URL=https://your_project_ref.supabase.co/functions/v1/shopify-webhook

# Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_URL            (usually auto)
# SUPABASE_SERVICE_ROLE_KEY (usually auto)
# SUPABASE_ANON_KEY       (or SUPABASE_PUBLISHABLE_KEY)
# SHOPIFY_CRON_SECRET     (for scheduled reconcile header; must match app_settings.shopify_cron_secret)

# Optional env fallbacks for Shopify (normally stored in app_settings table)
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ACCESS_TOKEN=
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# SHOPIFY_WEBHOOK_SECRET=
