<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let Apache serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback so React Router handles deep links and refresh.
  RewriteRule ^ index.html [L]
</IfModule>

